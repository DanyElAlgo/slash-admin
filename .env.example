# App
VITE_APP_DEFAULT_ROUTE=/workbench
VITE_APP_PUBLIC_PATH=/
VITE_APP_ROUTER_MODE=frontend

# API base URLs as the browser sees them. The defaults route through the vite
# dev-server proxy so nothing crosses CORS in local development. For a built
# bundle deployed behind your own reverse proxy, point these directly at the
# public API hosts (e.g. https://inventory.example.com/api).
VITE_APP_API_BASE_URL=/api
VITE_APP_INVENTORY_API_URL=/inventory-api
VITE_APP_SALES_API_URL=/sales-api
VITE_APP_PURCHASES_API_URL=/purchases-api

# Where the vite dev server forwards /inventory-api, /sales-api, /purchases-api and /api.
# Override these to point at API hosts on the LAN (e.g. http://192.168.1.20:5001).
VITE_DEV_PORT=3001
VITE_API_PROXY_TARGET=http://localhost:5000
VITE_INVENTORY_PROXY_TARGET=http://localhost:5001
VITE_SALES_PROXY_TARGET=http://localhost:5002
VITE_PURCHASES_PROXY_TARGET=http://localhost:5003
